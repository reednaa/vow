{
  "name": "vow-witness",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "bin": {
    "vow-witness": "src/cli.ts"
  },
  "scripts": {
    "start": "bun src/index.ts",
    "start:api": "bun src/entrypoints/api.ts",
    "start:worker": "bun src/entrypoints/worker.ts",
    "start:migrate": "bun src/entrypoints/migrate.ts",
    "dev": "bun --hot src/index.ts",
    "dev:admin": "cd admin && bun run dev",
    "build:admin": "cd admin && bun run build",
    "test": "bun test",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:push": "bunx drizzle-kit push"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.9"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@vow/protocol": "file:../typescript",
    "@elysiajs/jwt": "^1.4.1",
    "@elysiajs/static": "^1.4.7",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.213.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.213.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@solana/kit": "^6.9.0",
    "@solana/kit-client-rpc": "^0.11.1",
    "@types/bs58": "^5.0.0",
    "bs58": "^6.0.0",
    "drizzle-orm": "^0.45.1",
    "elysia": "^1.4.27",
    "graphile-worker": "^0.16.6",
    "postgres": "^3.4.8",
    "prool": "^0.2.3",
    "viem": "^2.47.0"
  }
}
