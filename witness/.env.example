# Required: 32-byte hex private key (64 hex chars), with or without 0x.
# Use a non-production key for local development.
WITNESS_PRIVATE_KEY=0x0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Required: PostgreSQL connection string.
DATABASE_URL=postgresql://vow:vow@localhost:5433/vow_witness

# Optional: API server port (default: 3000).
API_PORT=3000

# Optional: health server port (default: 3001).
HEALTH_PORT=3001
